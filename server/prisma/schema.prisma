generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "postgresql"
 url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String

  resumes   Resume[]

  createdAt DateTime @default(now())
}

model Resume {
  id         String   @id @default(uuid())

  fileUrl    String

  createdAt  DateTime @default(now())

  userId     String

  user       User @relation(fields: [userId], references: [id])
}